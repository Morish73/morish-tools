<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>テキスト整形ツール</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      margin: 0;
      padding: 0;
      background: #f7f7f8;
      color: #222;
    }

    .container {
      max-width: 960px;
      margin: 40px auto;
      padding: 24px;
      background: #fff;
      border: 1px solid #ddd;
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    h1 {
      margin-top: 0;
      font-size: 28px;
    }

    p.description {
      color: #555;
      margin-bottom: 24px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .panel {
      display: flex;
      flex-direction: column;
    }

    label {
      font-weight: bold;
      margin-bottom: 8px;
    }

    textarea {
      width: 100%;
      min-height: 320px;
      padding: 12px;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 14px;
      line-height: 1.5;
      resize: vertical;
      box-sizing: border-box;
      background: #fff;
    }

    .actions {
      margin: 20px 0;
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    button {
      padding: 10px 16px;
      border: 1px solid #bbb;
      border-radius: 8px;
      background: #f3f4f6;
      cursor: pointer;
      font-size: 14px;
    }

    button:hover {
      background: #e8eaed;
    }

    .sub-actions {
      margin-top: 12px;
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .message {
      margin-top: 12px;
      padding: 10px 12px;
      border-radius: 8px;
      background: #eef6ff;
      border: 1px solid #cfe3ff;
      color: #234;
    }

    .hint {
      margin-top: 10px;
      font-size: 13px;
      color: #666;
    }

    @media (max-width: 800px) {
      .grid {
        grid-template-columns: 1fr;
      }

      textarea {
        min-height: 220px;
      }
    }
  </style>
</head>
<body>
<div class="container">
  <h1>テキスト整形ツール</h1>
  <p class="description">
    改行区切りのテキストを、カンマ区切り・箇条書き・重複削除・ソートなどに変換します。
  </p>

  <form action="/format" method="post">
    <div class="grid">
      <div class="panel">
        <label for="inputText">入力</label>
        <textarea id="inputText" name="inputText" placeholder="ここにテキストを貼り付ける"><%= inputText %></textarea>
        <div class="hint">
          例：Java / Python / AWS を1行ずつ貼る
        </div>
      </div>

      <div class="panel">
        <label for="outputText">出力</label>
        <textarea id="outputText" readonly><%= outputText %></textarea>
        <div class="sub-actions">
          <button type="button" onclick="copyOutput()">出力をコピー</button>
          <button type="button" onclick="clearAll()">クリア</button>
        </div>
      </div>
    </div>

    <div class="actions">
      <button type="submit" name="mode" value="comma">改行 → カンマ区切り</button>
      <button type="submit" name="mode" value="bullet">改行 → 箇条書き</button>
      <button type="submit" name="mode" value="dedupe">重複削除</button>
      <button type="submit" name="mode" value="trim">前後空白を削除</button>
      <button type="submit" name="mode" value="doubleQuote">ダブルクォートで囲む</button>
      <button type="submit" name="mode" value="singleQuote">シングルクォートで囲む</button>
      <button type="submit" name="mode" value="sqlIn">SQLのIN句用にする</button>
      <button type="submit" name="mode" value="sortNum">数値ソート</button>
      <button type="submit" name="mode" value="sortJa">50音ソート</button>
      <button type="submit" name="mode" value="sortEn">アルファベットソート</button>
    </div>
  </form>

  <% if (message) { %>
    <div class="message"><%= message %></div>
  <% } %>
</div>

<script>
  function copyOutput() {
    const output = document.getElementById('outputText');
    output.select();
    output.setSelectionRange(0, 99999);
    document.execCommand('copy');
    alert('出力をコピーしました');
  }

  function clearAll() {
    window.location.href = '/';
  }
</script>
</body>
</html>