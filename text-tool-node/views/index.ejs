<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>テキスト整形ツール</title>
  <meta name="description" content="入力区切り・出力区切り・ソート・オプションを選んで、テキストを整形します。">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" href="/def_image.png" type="image/png">
</head>
<body class="page-text-format">
<div class="container">
  <%- include("partials/nav", { active: "text-format" }) %>

  <h1>テキスト整形ツール</h1>
  <p class="description">
    入力区切り・出力区切り・ソート・オプションを選んで、テキストを整形します。
  </p>

  <% if (message) { %>
    <div class="message"><%= message %></div>
  <% } %>

  <form action="/format" method="post">
    <div class="grid">
      <div class="panel">
        <label for="inputText">入力</label>
        <textarea id="inputText" name="inputText" placeholder="ここにテキストを貼り付ける"><%= inputText %></textarea>
      </div>

      <div class="panel">
        <label for="outputText">出力</label>
        <textarea id="outputText" readonly><%= outputText %></textarea>
        <div class="sub-actions">
          <button type="button" onclick="copyOutput()">出力をコピー</button>
          <button type="button" onclick="clearAll()">クリア</button>
          <button type="button" onclick="saveLocally()">ローカル保存</button>
          <button type="button" onclick="loadLocally()">保存を読込</button>
        </div>
      </div>
    </div>

    <div class="controls">
      <div class="control-box">
        <h3>ソート</h3>
        <label><input type="radio" name="sortOrder" value="none" <%= sortOrder === 'none' ? 'checked' : '' %>>なし</label>
        <label><input type="radio" name="sortOrder" value="asc" <%= sortOrder === 'asc' ? 'checked' : '' %>>昇順</label>
        <label><input type="radio" name="sortOrder" value="desc" <%= sortOrder === 'desc' ? 'checked' : '' %>>降順</label>
      </div>

      <div class="control-box">
        <h3>入力</h3>
        <label><input type="radio" name="inputDelimiter" value="comma" <%= inputDelimiter === 'comma' ? 'checked' : '' %>>カンマ</label>
        <label><input type="radio" name="inputDelimiter" value="space" <%= inputDelimiter === 'space' ? 'checked' : '' %>>空白</label>
        <label><input type="radio" name="inputDelimiter" value="tab" <%= inputDelimiter === 'tab' ? 'checked' : '' %>>タブ</label>
        <label><input type="radio" name="inputDelimiter" value="newline" <%= inputDelimiter === 'newline' ? 'checked' : '' %>>改行</label>
      </div>  
      
      <div class="control-box">
        <h3>出力</h3>
        <label><input type="radio" name="outputDelimiter" value="comma" <%= outputDelimiter === 'comma' ? 'checked' : '' %>>カンマ</label>
        <label><input type="radio" name="outputDelimiter" value="space" <%= outputDelimiter === 'space' ? 'checked' : '' %>>空白</label>
        <label><input type="radio" name="outputDelimiter" value="tab" <%= outputDelimiter === 'tab' ? 'checked' : '' %>>タブ</label>
        <label><input type="radio" name="outputDelimiter" value="newline" <%= outputDelimiter === 'newline' ? 'checked' : '' %>>改行</label>
      </div>

      <div class="control-box">
        <h3>オプション</h3>
        <label><input type="checkbox" name="options" value="dedupe" <%= options.includes('dedupe') ? 'checked' : '' %>>重複</label>
        <label><input type="checkbox" name="options" value="trim" <%= options.includes('trim') ? 'checked' : '' %>>trim</label>
      </div>

      <div class="control-box">
        <h3>囲み</h3>
        <label><input type="radio" name="quoteType" value="none" <%= quoteType === 'none' ? 'checked' : '' %>>なし</label>
        <label><input type="radio" name="quoteType" value="double" <%= quoteType === 'double' ? 'checked' : '' %>>"</label>
        <label><input type="radio" name="quoteType" value="single" <%= quoteType === 'single' ? 'checked' : '' %>>'</label>
      </div>
    </div>

    <div class="actions">
      <button type="submit" name="mode" value="normal">整形実行</button>
      <button type="submit" name="mode" value="sqlIn">SQL IN句に整形</button>
      <button type="submit" name="mode" value="jsonArray">JSON配列へ整形</button>
    </div>
  </form>
  <%- include("partials/footer") %>
</div>

<script>
  function copyOutput() {
    const output = document.getElementById('outputText');
    output.select();
    output.setSelectionRange(0, 99999);
    document.execCommand('copy');
    alert('出力をコピーしました');
  }

  function clearAll() {
    localStorage.removeItem('textFormatterInput');
    localStorage.removeItem('textFormatterOutput');
    window.location.href = '/text-format';
  }

  function saveLocally() {
    localStorage.setItem('textFormatterInput', document.getElementById('inputText').value);
    localStorage.setItem('textFormatterOutput', document.getElementById('outputText').value);
    alert('ブラウザに保存しました');
  }

  function loadLocally() {
    document.getElementById('inputText').value = localStorage.getItem('textFormatterInput') || '';
    document.getElementById('outputText').value = localStorage.getItem('textFormatterOutput') || '';
    alert('保存内容を読み込みました');
  }

  window.addEventListener('DOMContentLoaded', () => {
    const savedInput = localStorage.getItem('textFormatterInput');
    if (savedInput) {
      document.getElementById('inputText').value = savedInput;
    }
  });
</script>
</body>
</html>