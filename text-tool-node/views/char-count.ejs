<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>文字数カウントツール｜空白・改行除外対応</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="無料で使える文字数カウントツール。改行・空白を除外して正確にカウントできます。">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" href="/def_image.png" type="image/png">
</head>
<body class="page-char-count">

  <!-- ナビ -->
  <%- include("partials/nav", { active: "char-count" }) %>

  <h1>文字数カウントツール</h1>

  <p>
    テキストの文字数をリアルタイムでカウントできます。<br>
    空白や改行を除外したカウントにも対応しています。
  </p>

  <textarea id="inputText" placeholder="ここにテキストを入力してください..."><%= inputText || '' %></textarea>

  <div>
    <button onclick="clearText()">クリア</button>
    <button onclick="copyText()">コピー</button>
  </div>

  <div class="result">
    <p>総文字数：<span id="total">0</span></p>
    <p>空白除外：<span id="noSpaces">0</span></p>
    <p>改行除外：<span id="noNewlines">0</span></p>
    <p>空白・改行除外：<span id="noSpacesNewlines">0</span></p>
  </div>

  <div class="hint" id="hint"></div>

  <script>
    const textarea = document.getElementById('inputText');

    function updateCount() {
      const text = textarea.value;

      const total = text.length;
      const noSpaces = text.replace(/[ \u3000]/g, '').length;
      const noNewlines = text.replace(/\r?\n/g, '').length;
      const noSpacesNewlines = text
        .replace(/[ \u3000]/g, '')
        .replace(/\r?\n/g, '')
        .length;

      document.getElementById('total').textContent = total;
      document.getElementById('noSpaces').textContent = noSpaces;
      document.getElementById('noNewlines').textContent = noNewlines;
      document.getElementById('noSpacesNewlines').textContent = noSpacesNewlines;

      updateHint(total);
    }

    function updateHint(count) {
      let message = '';

      if (count === 0) {
        message = '';
      } else if (count <= 140) {
        message = '短文SNSやメモに適した長さです';
      } else if (count <= 280) {
        message = 'X（旧Twitter）の投稿にちょうどいい長さです';
      } else if (count <= 500) {
        message = '少し長めの説明文に適しています';
      } else if (count <= 1000) {
        message = '記事や解説文として使える長さです';
      } else {
        message = '長文コンテンツ（ブログなど）向けのボリュームです';
      }

      document.getElementById('hint').textContent = message;
    }

    function clearText() {
      textarea.value = '';
      updateCount();
    }

    function copyText() {
      textarea.select();
      document.execCommand('copy');
      alert('コピーしました');
    }

    textarea.addEventListener('input', updateCount);

    // 初期実行
    updateCount();
  </script>
  <%- include("partials/footer") %>

</body>
</html>